# Codega Theme CSS klasörü
# Eğer wisecp.css fiziksel olarak varsa (static), Apache direkt onu yükler.
# Yoksa wisecp.php'ye internal rewrite yapılır.

<IfModule mod_rewrite.c>
RewriteEngine On

# Sadece dosya YOKSA rewrite yap (defansif fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^wisecp\.css$ wisecp.php [L]
</IfModule>
