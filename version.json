    "changelog": [
        "v3.7.1 - SEPET URL DUZELTME (TR=siparis, EN=order-steps)",
        "",
        "[KOK NEDEN]",
        "+ WiseCP'nin website-routes haritasinda TR locale icin slug:",
        "  'order-steps-p' => 'siparis/(?)/(?)/(?)' degil 'order-steps/...'",
        "+ Yani gercek URL /siparis/hosting/103/1 (codega.com.tr/siparis/hosting/103)",
        "+ Onceki surumlerde /order-steps/hosting/103 olarak insa edilmisti, 404 doniyordu",
        "",
        "[YENI: inc/cdg-route-helper.php (190 satir)]",
        "+ cdg_route(slug, params) - WiseCP slug'i gercek URL'e cevirir",
        "+ cdg_buy_link(type, id) - Urun satin alma linki (TR=siparis, EN=order-steps)",
        "+ cdg_basket_link() - Sepet sayfasi linki (/sepet)",
        "+ cdg_get_website_routes() - Aktif dilin route haritasini cache'le okur",
        "",
        "[3 KATMANLI URL INSAASI]",
        "1) Once Controllers::CRLink dene (WiseCP'nin kendi yontemi)",
        "2) Basarisizsa: website-routes.php'yi okuyup pattern'a parametreleri yerlestir",
        "3) Son care: hardcoded fallback (/siparis/{type}/{id})",
        "",
        "[GERCEK TEST SONUCLARI]",
        "+ cdg_buy_link('hosting', 103) -> /siparis/hosting/103/1 (codega.com.tr/siparis/hosting/103)",
        "+ cdg_buy_link('hosting', 16)  -> /siparis/hosting/16/1",
        "+ cdg_buy_link('server', 50)   -> /siparis/server/50/1",
        "+ cdg_basket_link()            -> /sepet",
        "",
        "[DEGISIKLIKLER]",
        "+ index.php           : cdg_buy_link kullanildi (anasayfa hosting paketleri)",
        "+ cdg-product-list-template.php : cdg_buy_link kullanildi (server/sms/special)",
        "+ main-header-1.php   : cdg_basket_link header'da",
        "+ main-header-2.php   : cdg_basket_link header'da",
        "",
        "[Devralinanlar v3.7.0]",
        "+ dev.wisecp.com modul entegrasyonu (run_transaction, custom pages, SSO)",
        "+ ClientAreaMenus / DashboardBottom / InvoiceQRCode hooks"
    ]
